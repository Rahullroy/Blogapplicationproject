<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>Edit Blog</h1>

<form action="/update/<%= index %>" method="POST">

    <input 
        type="text" 
        name="title" 
        value="<%= blog.title %>"
    >

    <textarea name="content"><%= blog.content %></textarea>

    <button type="submit">UPDATE</button>

</form>
</body>
</html>